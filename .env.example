# ---------------------------------------------------------------------------
# DealLens Diligence Lab — environment configuration
# Copy to .env (Docker) or apps/api/.env (local) and adjust as needed.
# The app runs fully in MOCK mode with NO API key and NO external services.
# ---------------------------------------------------------------------------

# LLM mode: "mock" (default) = fully deterministic real-data generation, NO key required.
# "live" additionally re-voices the memo/bear-case prose via an LLM (numbers never change).
LLM_MODE=mock

# --- Live LLM (only used when LLM_MODE=live) -------------------------------
# Anthropic Messages API by default (or any OpenAI-compatible endpoint).
LLM_API_KEY=
LLM_BASE_URL=https://api.anthropic.com/v1
LLM_MODEL=claude-opus-4-8

# --- Database -------------------------------------------------------------
# Local default: SQLite file (no server needed). Docker overrides with Postgres.
DATABASE_URL=sqlite:///./data/deallens.sqlite3
# Apply Alembic migrations automatically at local process startup. Container orchestration can use
# SCHEMA_MANAGEMENT=external after running `alembic upgrade head` in its entrypoint.
SCHEMA_MANAGEMENT=migrate
# Postgres example (used by docker-compose):
# DATABASE_URL=postgresql+psycopg://deallens:deallens@db:5432/deallens

# --- Backend --------------------------------------------------------------
API_HOST=0.0.0.0
API_PORT=8000
# Comma-separated allowed CORS origins for the web app
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
# Auto-seed real demo workspaces (MSFT, CRWD) from live SEC on first startup if the DB is empty.
# Off by default so startup stays fast/offline-safe; run `python -m src.seed.load_seed` to populate.
AUTO_SEED=false
# Required for demo seeding only when multiple organizations exist.
SEED_ORGANIZATION_SLUG=
# Require a revocable DealLens session (or the separately configured trusted-service credential).
AUTH_REQUIRED=true
INTERNAL_API_TOKEN=
AUTH_ALLOW_REGISTRATION=false
AUTH_SESSION_HOURS=12
AUTH_MAX_FAILED_LOGINS=5
AUTH_LOCKOUT_MINUTES=15
AUTH_RATE_LIMIT_ATTEMPTS=30
AUTH_RATE_LIMIT_WINDOW_SECONDS=60
# Fernet key used to encrypt outbound webhook signing secrets at rest.
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
WEBHOOK_ENCRYPTION_KEY=
WEBHOOK_ALLOW_INSECURE_HTTP=false

# --- Public demo posture (all optional; defaults off) -----------------------
# DEMO_MODE=true enables the one-click "Try the demo" guest login and per-IP
# throttling of SEC-bound build endpoints on a hosted demo box.
DEMO_MODE=false
DEMO_BUILDS_PER_HOUR=6
DEMO_RETENTION_HOURS=72
# Cache EDGAR responses on disk for this many seconds (0 = always live).
# Recommended for hosted demos: 21600 (6 hours).
EDGAR_CACHE_TTL_SECONDS=0

# --- SEC EDGAR (PRIMARY data source — required, no key) --------------------
# SEC requires a descriptive User-Agent (name + email) per their fair-access policy. Set yours.
SEC_USER_AGENT=DealLens Diligence Lab (portfolio project) contact@example.com

# --- Other public data sources (extensions) -------------------------------
FRED_API_KEY=
OPENFIGI_API_KEY=
SAM_GOV_API_KEY=

# --- Frontend -------------------------------------------------------------
NEXT_PUBLIC_API_URL=http://localhost:8000

# =============================================================================
# DealLens — public demo (single VPS) environment template.
#
#   cp .env.prod.example .env      # then edit the values below
#
# docker-compose.yml reads these via ${VAR} interpolation; docker-compose.prod.yml
# also passes .env to the demo-cleanup worker. Do NOT commit the resulting .env
# (it is gitignored). Values with spaces do NOT need quotes in this file.
# =============================================================================

# ---- Public entrypoint (Caddy) ---------------------------------------------
# The hostname whose DNS A/AAAA record points at this VPS. Caddy gets a TLS cert
# for it automatically on first boot, so set the DNS record BEFORE `up`.
PUBLIC_DOMAIN=demo.yourdomain.com

# ---- SEC fair-access (REQUIRED) --------------------------------------------
# The SEC requires a descriptive User-Agent with a real contact. Requests without
# one get rate-limited or blocked. Use your own name and email.
SEC_USER_AGENT=DealLens demo (Your Name) you@example.com

# ---- Demo posture -----------------------------------------------------------
DEMO_MODE=true                 # enables the "Try the demo" guest button + per-IP throttle
DEMO_BUILDS_PER_HOUR=6         # SEC-bound builds allowed per client IP per hour
DEMO_RETENTION_HOURS=72        # how long guest workspaces/identities live before cleanup
EDGAR_CACHE_TTL_SECONDS=21600  # 6h disk cache of EDGAR JSON/filings — fast repeat visits

# ---- Auth (keep these as-is for a public box) ------------------------------
AUTH_REQUIRED=true             # NEVER run a public instance with this false
AUTH_ALLOW_REGISTRATION=false  # first /register bootstraps the owner, then self-signup is off
AUTH_SESSION_HOURS=12

# ---- AI / LLM ---------------------------------------------------------------
# mock = $0, no key, fully functional and deterministic. To showcase live LLM later:
#   LLM_MODE=live
#   LLM_API_KEY=sk-ant-...          # your Anthropic key
#   ORG_LLM_QUOTA_PER_HOUR=20       # hard hourly spend ceiling for the shared demo org
LLM_MODE=mock

# ---- Optional features (leave blank to disable) ----------------------------
# Signed/encrypted webhook secrets. Generate with:
#   docker compose run --rm api python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
WEBHOOK_ENCRYPTION_KEY=

# Ed25519 export attestation (G74): base64url-encoded 32-byte seed. Generate with:
#   docker compose run --rm api python -c "import base64,os; print(base64.urlsafe_b64encode(os.urandom(32)).decode())"
EXPORT_SIGNING_KEY=
